{
  "expo": {
    "name": "SAFPRO",
    "slug": "safpro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "safpro",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1c2b4b"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.safpro.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#070c18"
      },
      "package": "com.safpro.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [{ "scheme": "safpro" }],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "safpro.us",
              "pathPrefix": "/verify-email"
            },
            {
              "scheme": "https",
              "host": "safpro.us",
              "pathPrefix": "/payment-success"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6366f1",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "SAFPRO"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "59794fe6-4cfa-4446-b9d7-28a401e17185"
      }
    },
    "owner": "alrx12"
  }
}
