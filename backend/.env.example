# ── SAFPRO — Variables de entorno de producción ───────────────────────────────
#
# Copia este archivo a backend/.env y rellena los valores marcados con ← CAMBIAR
# NO commitees backend/.env al repositorio — contiene secretos
#
# Nota: DATABASE_URL y REDIS_URL son sobreescritas en docker-compose.yml
# para usar los hostnames internos de Docker (postgres:5432, redis:6379).
# Los valores aquí son para desarrollo local sin Docker.
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME=SAFPRO API
APP_VERSION=0.1.0

# ── Seguridad ─────────────────────────────────────────────────────────────────
# DEBUG=false activa: rate limiting, errores genéricos, email real en forgot-password
DEBUG=false                                              # ← CAMBIAR (true solo para dev local)

# Genera una clave segura: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIAR_POR_CLAVE_SEGURA_ALEATORIA_DE_64_CHARS  # ← CAMBIAR

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Base de datos ─────────────────────────────────────────────────────────────
# En Docker, docker-compose.yml sobreescribe esta variable.
# Aquí solo sirve para desarrollo local sin Docker.
DATABASE_URL=postgresql+psycopg://safpro:tu_password@localhost:5432/safpro

# ── Redis / Celery ────────────────────────────────────────────────────────────
# En Docker, docker-compose.yml sobreescribe esta variable.
REDIS_URL=redis://localhost:6379/0

# ── Almacenamiento de archivos ────────────────────────────────────────────────
# Estas rutas son relativas al directorio de trabajo (/app en Docker).
# El volumen Docker se monta en /app/storage — no cambiar en producción Docker.
UPLOAD_DIR=storage/uploads
PROCESSED_DIR=storage/processed
TEMP_DIR=storage/temp
KNOWLEDGE_BASES_DIR=storage/knowledge_bases

# ── Email (reset de contraseña) ───────────────────────────────────────────────
# Crea tu cuenta en resend.com, verifica tu dominio y obtén la API key.
RESEND_API_KEY=re_CAMBIAR_POR_TU_API_KEY               # ← CAMBIAR
EMAIL_FROM=SAFPRO <noreply@tu-dominio.com>              # ← CAMBIAR (debe coincidir con dominio verificado en Resend)

# URL base del frontend — se usa para el link de reset de contraseña en el email
# En producción: https://tu-dominio.com o http://IP_DEL_SERVIDOR (si no tienes dominio aún)
FRONTEND_URL=http://IP_DEL_SERVIDOR                     # ← CAMBIAR
