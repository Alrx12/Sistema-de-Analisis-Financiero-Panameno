# ── SAFPRO — Ejemplo de configuración ───────────────────────────────────────
# Copia este archivo a .env y llena los valores reales.
# NUNCA commitees el .env real — está en .gitignore.
#
# Para desarrollo local (con docker-compose.dev.yml):
#   DATABASE_URL=postgresql+psycopg://safpro_dev:safpro_dev@localhost:5432/safpro
#   REDIS_URL=redis://localhost:6379/0
#   DEBUG=true
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME=SAFPRO API
APP_VERSION=0.1.0

# En true: muestra errores reales y retorna token en forgot-password (solo dev)
DEBUG=true

# Base de datos PostgreSQL
DATABASE_URL=postgresql+psycopg://USUARIO:CONTRASEÑA@localhost:5432/safpro

# Clave secreta JWT — genera una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esto_por_una_clave_larga_y_aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Directorios de almacenamiento (relativos a backend/)
UPLOAD_DIR=storage/uploads
PROCESSED_DIR=storage/processed
TEMP_DIR=storage/temp
KNOWLEDGE_BASES_DIR=storage/knowledge_bases

# Redis (para Celery)
REDIS_URL=redis://localhost:6379/0

# Resend — para emails de reset de contraseña (obtén la key en resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=SAFPRO <noreply@tudominio.com>

# URL base del frontend (usada en el link de reset de contraseña)
FRONTEND_URL=http://localhost:3000
